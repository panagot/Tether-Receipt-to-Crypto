PORT=3847

# Optional: force FX→USD rates for USDT settlement hints (otherwise Frankfurter / built-in fallbacks).
# EUR_USD_RATE=1.085
# GBP_USD_RATE=1.27
# JPY_USD_RATE=0.0068
# (same pattern: {ISO}_USD_RATE for supported receipt currencies)

# Vercel only (serverless proxy in `api/` — not read by local Express): forward /api/* to your tunnel or host.
# RTC_API_PROXY_TARGET=https://xxxx.ngrok-free.app

# Optional: for `npm run vercel:env-snippet` — print this origin without starting a tunnel.
# RTC_PUBLIC_API_URL=https://xxxx.trycloudflare.com
# Optional: full path to cloudflared.exe if not on PATH (Windows MSI default below).
# RTC_CLOUDFLARED_BIN=C:\Program Files (x86)\cloudflared\cloudflared.exe

# Client (Vite): when the UI is static-only (e.g. Vercel), set at *build* time so fetches hit your API:
# VITE_API_BASE_URL=https://abc123.ngrok-free.app
# Or without redeploy: open the deployed URL once with ?rtc_api=https://abc123.ngrok-free.app (HTTPS only).
# Set to false if Vulkan/GPU hangs during OCR (slower CPU path).
# QVAC_USE_GPU=true

# EasyOCR language list (comma-separated). Wider = slower first load + more VRAM/RAM.
# Default on the server includes Latin, Greek, Arabic, Chinese (simplified), Japanese, Korean, Hindi, Thai.
# QVAC_OCR_LANG_LIST=en,el,ar,ch_sim,ja,ko,hi,th

# When true, POST /api/extract includes extractDebug (timings, OCR char count, langs used) for the client.
# RTC_EXTRACT_DEBUG=1
SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional when using a private RPC host (for explorer links + UI label)
# SOLANA_CLUSTER=devnet
USDT_MINT=
WALLET_SEED=

# Optional: force QVAC receipt-search embedding model (registryPath substring match).
# RTC_EMBEDDING_REGISTRY_PATH=qvac_models_compiled/embeddings/…/model-name.gguf
