{
  "name": "receipt-to-crypto",
  "version": "0.1.0",
  "private": true,
  "description": "Local QVAC OCR + LLM receipt extraction, optional WDK USDT payment",
  "repository": {
    "type": "git",
    "url": "https://github.com/panagot/Tether-Receipt-to-Crypto.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.17.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "build": "tsc -p server/tsconfig.json --noEmit && vite build --config client/vite.config.ts",
    "start": "node --import tsx server/index.ts"
  },
  "dependencies": {
    "@qvac/sdk": "^0.9.1",
    "@tetherto/wdk-wallet-solana": "^1.0.0-beta.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "tinyld": "1.3.4",
    "zod": "^3.23.8"
  },
  "overrides": {
    "esbuild": "0.21.5"
  },
  "devDependencies": {
    "esbuild": "0.21.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^8.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
